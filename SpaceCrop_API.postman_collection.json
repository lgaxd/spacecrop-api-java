              "raw": "{{baseUrl}}/usuarios?page=0&size=10&sort=id",
              "host": ["{{baseUrl}}"],
              "path": ["usuarios"],
              "query": [
                { "key": "nome", "value": "", "disabled": true },
                { "key": "email", "value": "", "disabled": true },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" },
                { "key": "sort", "value": "id" }
              ]
