{
  "info": {
    "name": "SpaceCrop API",
    "description": "Collection completa para testes da SpaceCrop API — Global Solution 2026/1 FIAP.\n\n**Como usar:**\n1. Importe esta collection no Postman\n2. Crie um Environment com a variável `baseUrl` = `http://localhost:8080`\n3. Execute **Auth > Register** para criar sua conta\n4. Execute **Auth > Login** — o token JWT será salvo automaticamente na variável `token`\n5. Todos os demais requests já usam `{{token}}` no header Authorization",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "usuarioId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "fazendaId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "setorId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "sateliteId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "sensorId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "leituraId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "alertaId",
      "value": "1",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    pm.collectionVariables.set('usuarioId', json.id);",
                  "    console.log('Token salvo:', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Lucas Grillo\",\n  \"email\": \"lucas@spacecrop.com\",\n  \"senha\": \"senha123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            },
            "description": "Cadastra um novo usuário. O token JWT retornado é salvo automaticamente na variável `token`."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    pm.collectionVariables.set('usuarioId', json.id);",
                  "    console.log('Login OK. Token salvo.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"lucas@spacecrop.com\",\n  \"senha\": \"senha123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Autentica o usuário e salva o JWT em `{{token}}`."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout"]
            },
            "description": "Realiza logout (stateless — invalida sessão no lado do cliente)."
          }
        }
      ]
    },
    {
      "name": "👤 Usuários",
      "item": [
        {
          "name": "Listar Usuários",
          "request": {
            "method": "GET",
