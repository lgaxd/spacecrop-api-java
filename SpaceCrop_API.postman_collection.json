    {
      "name": "🔁 Fluxo Completo (E2E)",
      "description": "Execute os requests nesta ordem para testar o fluxo completo da aplicação do zero.",
      "item": [
        {
          "name": "1. Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
