            "description": "Retorna os dados do usuário autenticado. Só é possível buscar o próprio usuário."
          }
        },
        {
          "name": "Atualizar Usuário",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Lucas Grillo Alcântara\",\n  \"email\": \"lucas.novo@spacecrop.com\",\n  \"senha\": \"novaSenha456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/usuarios/{{usuarioId}}",
              "host": ["{{baseUrl}}"],
              "path": ["usuarios", "{{usuarioId}}"]
            },
            "description": "Atualiza nome, email e/ou senha. Todos os campos são opcionais."
          }
        },
        {
          "name": "Deletar Usuário",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/usuarios/{{usuarioId}}",
              "host": ["{{baseUrl}}"],
              "path": ["usuarios", "{{usuarioId}}"]
            },
            "description": "Remove um usuário do sistema. Retorna 204 No Content."
          }
        }
      ]
    },
